# =============================================================================
# versions.env — single-source-of-truth pin manifest for the AV firmware build
# =============================================================================
# All version numbers, USB IDs, hostnames, and external URLs are pinned here.
# Tools (Makefile, scripts/lib/config.sh, CI) read this file as KEY=VALUE.
# Comments start with `#`. Do not include inline comments on KEY=VALUE lines.
# =============================================================================

# --- L4T / JetPack baseline --------------------------------------------------
L4T_VERSION=R36.5.0
JETPACK_VERSION=6.2.2
KERNEL_BASE_VERSION=5.15
LOCALVERSION=-tegra

# --- Toolchain (Bootlin, locked) ---------------------------------------------
BOOTLIN_TOOLCHAIN=aarch64--glibc--stable-2022.08-1
BOOTLIN_PREFIX=aarch64-buildroot-linux-gnu-
TOOLCHAIN_INSTALL_PREFIX=/opt

# --- Required NVIDIA tarballs (must live next to repo root) ------------------
TARBALL_L4T=Jetson_Linux_R36.5.0_aarch64.tbz2
TARBALL_ROOTFS=Tegra_Linux_Sample-Root-Filesystem_R36.5.0_aarch64.tbz2
TARBALL_PUBLIC_SOURCES=public_sources.tbz2

# --- External vendor trees (gitignored, must be cloned/placed) ---------------
EXTERNAL_AXELERA_DRIVER=axelera-driver
EXTERNAL_VOYAGER_SDK=voyager-sdk
EXTERNAL_ZEDX_DRIVER=zedx-driver
EXTERNAL_ZED_SDK=zed-sdk

# --- CUDA / Python stack -----------------------------------------------------
CUDA_VERSION=12.6
PYTORCH_VERSION=2.7.0
TORCHVISION_VERSION=0.22.0
PYTORCH_INDEX_URL=https://pypi.jetson-ai-lab.dev/jp6/cu126
NUMPY_CONSTRAINT="numpy<2.0.0"
# Verified canonical pip extra-index URL (the /api/pypi/.../simple suffix
# is required for pip's index API).
VOYAGER_PYPI_URL=https://software.axelera.ai/artifactory/api/pypi/axelera-pypi/simple

# --- ZED SDK -----------------------------------------------------------------
ZED_SDK_VERSION=5.3
ZED_SDK_INSTALLER_GLOB=ZED_SDK_Tegra_*.run

# --- Hardware target ---------------------------------------------------------
# TARGET_BOARD must match a *.conf file inside Linux_for_Tegra/ (the flasher
# reads it as the board target). Wrong value = flash succeeds but device fails
# to boot. `make doctor --only flash` validates the value against the
# extracted L4T tree before you flash.
#
# Verified board targets for Orin NX 16GB in L4T R36.5:
#   p3509-a02+p3767-0000          ← canonical (P3767 module + P3509 carrier)
#   jetson-orin-nano-devkit       ← alias of the above; correct for all
#                                    P3509-class carriers with Orin NX 16GB
# Do NOT use:
#   jetson-orin-nano-devkit-super ← Orin NANO power-table variant ONLY; will
#                                    misconfigure the Orin NX power profile
#
TARGET_BOARD=jetson-orin-nano-devkit

# Boot storage device. p1 is the rootfs partition number written by the
# l4t_initrd_flash NVMe XML.
TARGET_STORAGE_DEV=nvme0n1p1

# L4T flash XML files (relative to Linux_for_Tegra/). Override per-board.
TARGET_FLASH_XML=tools/kernel_flash/flash_l4t_t234_nvme.xml
TARGET_QSPI_XML=bootloader/generic/cfg/flash_t234_qspi.xml

TARGET_HOSTNAME=jetson
TARGET_USER=j
TARGET_USB_IP=192.168.55.1

# Pixhawk TELEM2 → Jetson UART1 → /dev/ttyTHS1.
# /dev/ttyTHS0 is the debug console — do NOT use it for MAVLink.
# Verify with `dmesg | grep tty` on actual hardware before mission.
# Override in .config via CONFIG_FCU_TTY if your carrier wires differently.
FCU_TTY_DEFAULT=/dev/ttyTHS1
FCU_BAUD_DEFAULT=921600

# Iridium model. The 9704 uses Iridium Messaging Transport (IMT) via JSPR JSON
# over FTDI USB-serial (/dev/ttyUSB0) at 230400 baud.
# The 9602/9603 (legacy) use SBD AT commands over CDC-ACM (/dev/ttyACM0) at 19200.
# Our relay supports both via this knob.
IRIDIUM_MODEL=9704

# --- USB IDs (recovery / RNDIS gadget) ---------------------------------------
USB_ID_APX=0955:7323
USB_ID_RNDIS=0955:7035

# --- RT tuning (must agree with extlinux.conf injection + jetson_rt_tune) ----
RT_ISOLATED_CORES=1-5
RT_BOOT_ARGS="nohz_full=1-5 isolcpus=1-5 rcu_nocbs=1-5 irqaffinity=0 efi=noruntime pcie_aspm=off cma=2G"

# --- Critical kernel patches (sanity check values) ---------------------------
PCIE_LINK_WAIT_MAX_RETRIES=100
CMA_SIZE_MBYTES=2048

# --- Docker --------------------------------------------------------------------
DOCKER_IMAGE_TAG=jetson-av-builder
