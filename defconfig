# jetson-rt-stack default build configuration
# Generated by: make savedefconfig
# Load with:    make defconfig
# Customize:    make menuconfig && make savedefconfig
#
# This is the "full stack" profile: PREEMPT_RT, ZED Link Mono, Axelera Metis,
# MAXN_SUPER power mode, Isaac ROS source build.
# All values below match the defaults in Kconfig — included here for clarity.
CONFIG_KERNEL_PREEMPT_RT=y
CONFIG_LOW_JITTER=y
CONFIG_ISOLATED_CORE_RANGE="1-5"
CONFIG_CMA_SIZE_MBYTES=2048
CONFIG_CAMERA_ZEDX_MONO=y
CONFIG_DMABUF_ZEROCOPY=y
CONFIG_ZEDX_SDK_AUTO_INSTALL=y
CONFIG_AXELERA_METIS=y
CONFIG_METIS_POWER_CAP_W=18
CONFIG_PCIE_LINK_WAIT_MAX_RETRIES=100
CONFIG_AXELERA_PROMOTE_INTREE=y
CONFIG_AXELERA_UDEV_RULES=y
CONFIG_VOYAGER_SDK=y
CONFIG_NVPMODEL_MAXN_SUPER=y
CONFIG_ISAAC_ROS_SOURCE=y
CONFIG_FCU_MAVROS=y
CONFIG_FCU_TTY="/dev/ttyTHS1"
CONFIG_FCU_BAUD=921600
