# Gemfile for local Jekyll preview of the GitHub Pages site.
#
# Usage:
#   cd docs/
#   bundle install
#   bundle exec jekyll serve
# Then open http://127.0.0.1:4000/jetson_firmware
#
# Not needed in production — GitHub Pages builds the site server-side using
# its own pinned gem versions. This Gemfile is for local development.

source "https://rubygems.org"

# `github-pages` pins the exact gem versions GitHub Pages uses, so what you
# see locally matches what gets built on push.
gem "github-pages", group: :jekyll_plugins

# `just-the-docs` is the theme. Newer versions are picked up automatically by
# the github-pages gem; this line is informational.
gem "just-the-docs"

# Jekyll plugins (also listed in _config.yml under `plugins:`).
group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-redirect-from"
end

# Windows / JRuby compatibility (harmless on Linux/macOS).
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]
